idth":"6","height":"4","gtype":"gage","title":"🏔️ Total Peak Shaving","label":"kWh","format":"{{value | number:1}}","min":0,"max":"1000","colors":["#ca3838","#e6e600","#00b500"],"seg1":"100","seg2":"500","x":1510,"y":640,"wires":[]},{"id":"avg_buffer_gauge","type":"ui_gauge","z":"64ff3f75.7d53b8","name":"Average Buffer Fill","group":"energy_overview_group","order":3,"width":"6","height":"4","gtype":"gage","title":"🔋 Avg Buffer Fill","label":"%","format":"{{value | number:1}}","min":0,"max":"100","colors":["#ca3838","#e6e600","#00b500"],"seg1":"30","seg2":"70","x":1510,"y":680,"wires":[]},{"id":"cluster_count_gauge","type":"ui_gauge","z":"64ff3f75.7d53b8","name":"Active Clusters","group":"energy_overview_group","order":4,"width":"6","height":"4","gtype":"gage","title":"🏭 Active Clusters","label":"clusters","format":"{{value}}","min":0,"max":"10","colors":["#ca3838","#e6e600","#00b500"],"seg1":"3","seg2":"7","x":1510,"y":720,"wires":[]},{"id":"update_table","type":"function","z":"64ff3f75.7d53b8","name":"Generate Table","func":"var allClusters = global.get('energy_clusters') || {}; var html = '<style> .energy-table { width: 100%; border-collapse: collapse; font-family: Arial, sans-serif; font-size: 12px; margin: 10px 0; } .energy-table th, .energy-table td { border: 1px solid #ddd; padding: 8px; text-align: center; } .energy-table th { background: linear-gradient(45deg, #667eea, #764ba2); color: white; font-weight: bold; } .energy-table tr:nth-child(even) { background-color: #f9f9f9; } .efficiency-good { background-color: #d4edda !important; color: #155724; } .efficiency-medium { background-color: #fff3cd !important; color: #856404; } .efficiency-poor { background-color: #f8d7da !important; color: #721c24; } .buffer-full { background-color: #d4edda !important; } .buffer-medium { background-color: #fff3cd !important; } .buffer-low { background-color: #f8d7da !important; } .impact-positive { background-color: #d4edda !important; color: #155724; } .impact-negative { background-color: #f8d7da !important; color: #721c24; } .status-active { color: #28a745; font-weight: bold; } .status-inactive { color: #dc3545; } </style> <table class=\"energy-table\"> <thead> <tr> <th>Cluster</th> <th>Buffer Efficiency (%)</th> <th>Buffer Fill (%)</th> <th>Net Grid Impact (kWh)</th> <th>Peak Shaving (kWh)</th> <th>From Buffer (kWh)</th> <th>From Grid (kWh)</th> <th>Proactive Charging</th> <th>Last Update</th> </tr> </thead> <tbody>'; var sortedClusters = Object.keys(allClusters).sort(function(a, b) { var numA = parseInt(a.replace('cluster_', '')); var numB = parseInt(b.replace('cluster_', '')); return numA - numB; }); for (var i = 0; i < sortedClusters.length; i++) { var clusterId = sortedClusters[i]; var cluster = allClusters[clusterId]; var efficiencyClass = ''; if (cluster.buffer_utilization >= 30) efficiencyClass = 'efficiency-good'; else if (cluster.buffer_utilization >= 10) efficiencyClass = 'efficiency-medium'; else efficiencyClass = 'efficiency-poor'; var bufferClass = ''; if (cluster.buffer_fill_percentage >= 70) bufferClass = 'buffer-full'; else if (cluster.buffer_fill_percentage >= 30) bufferClass = 'buffer-medium'; else bufferClass = 'buffer-low'; var impactClass = cluster.net_grid_impact >= 0 ? 'impact-positive' : 'impact-negative'; var impactSymbol = cluster.net_grid_impact >= 0 ? '↑' : '↓'; var proactiveStatus = cluster.is_proactive_charging ? '<span class=\"status-active\">✓ Active</span>' : '<span class=\"status-inactive\">✗ Inactive</span>'; var timestamp = new Date(cluster.timestamp).toLocaleTimeString(); html += '<tr> <td><strong>' + clusterId + '</strong></td> <td class=\"' + efficiencyClass + '\">' + cluster.buffer_utilization + '%</td> <td class=\"' + bufferClass + '\">' + cluster.buffer_fill_percentage + '%</td> <td class=\"' + impactClass + '\">' + impactSymbol + ' ' + Math.abs(cluster.net_grid_impact) + '</td> <td>' + cluster.peak_shaving_benefit + '</td> <td>' + cluster.energy_from_buffer + '</td> <td>' + cluster.energy_from_grid_direct + '</td> <td>' + proactiveStatus + '</td> <td>' + timestamp + '</td> </tr>'; } html += '</tbody> </table> <div style=\"margin-top: 15px; padding: 10px; background: #f8f9fa; border-radius: 5px; font-size: 11px;\"> <strong>Legend:</strong> <span style=\"background: #d4edda; padding: 2px 6px; margin: 0 5px; border-radius: 3px;\">Good Performance</span> <span style=\"background: #fff3cd; padding: 2px 6px; margin: 0 5px; border-radius: 3px;\">Medium Performance</span> <span style=\"background: #f8d7da; padding: 2px 6px; margin: 0 5px; border-radius: 3px;\">Poor Performance</span> </div>'; msg.payload = html; return msg;","outputs":1,"x":1240,"y":720,"wires":[["cluster_table_display"]]},{"id":"cluster_table_display","type":"ui_template","z":"64ff3f75.7d53b8","group":"cluster_metrics_group","name":"Cluster Metrics Table","order":1,"width":"24","height":"12","format":"{{msg.payload}}","storeOutMessages":false,"fwdInMessages":false,"resendOnRefresh":true,"templateScope":"local","x":1540,"y":800,"wires":[[]]}]