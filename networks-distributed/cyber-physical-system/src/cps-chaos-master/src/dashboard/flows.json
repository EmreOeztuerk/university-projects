ers') || {}; allClusters[clusterId] = { cluster_id: clusterId, timestamp: data.timestamp, buffer_utilization: Math.round(data.buffer_utilization * 100 * 10) / 10, buffer_fill_percentage: Math.round(data.buffer_fill_percentage * 10) / 10, net_grid_impact: Math.round(data.net_grid_impact * 10) / 10, peak_shaving_benefit: Math.round(data.peak_shaving_benefit * 10) / 10, energy_from_buffer: Math.round(data.energy_from_buffer * 10) / 10, energy_from_grid_direct: Math.round(data.energy_from_grid_direct * 10) / 10, is_proactive_charging: data.is_proactive_charging, current_buffer_level: Math.round(data.current_buffer_level * 10) / 10 }; global.set('energy_clusters', allClusters); var bufferUtilMsg = { payload: data.buffer_utilization * 100, topic: 'Buffer Efficiency ' + clusterId }; var bufferFillMsg = { payload: data.buffer_fill_percentage, topic: 'Buffer Level ' + clusterId }; var gridImpactMsg = { payload: data.net_grid_impact, topic: 'Grid Impact ' + clusterId }; var peakShavingMsg = { payload: data.peak_shaving_benefit, topic: 'Peak Shaving ' + clusterId }; var totalBufferEnergy = 0; var totalGridEnergy = 0; var totalPeakShaving = 0; var avgBufferFill = 0; var clusterCount = 0; for (var cluster in allClusters) { var c = allClusters[cluster]; totalBufferEnergy += c.energy_from_buffer || 0; totalGridEnergy += c.energy_from_grid_direct || 0; totalPeakShaving += c.peak_shaving_benefit || 0; avgBufferFill += c.buffer_fill_percentage || 0; clusterCount++; } var systemEfficiency = totalBufferEnergy + totalGridEnergy > 0 ? (totalBufferEnergy / (totalBufferEnergy + totalGridEnergy)) * 100 : 0; avgBufferFill = clusterCount > 0 ? avgBufferFill / clusterCount : 0; var systemMsg = { payload: { system_efficiency: Math.round(systemEfficiency * 10) / 10, total_peak_shaving: Math.round(totalPeakShaving * 10) / 10, avg_buffer_fill: Math.round(avgBufferFill * 10) / 10, active_clusters: clusterCount }, topic: 'system_totals' }; var tableMsg = { payload: 'update', topic: 'trigger_table' }